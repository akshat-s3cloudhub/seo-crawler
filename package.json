{
  "name": "seo-crawler",
  "version": "1.0.0",
  "private": true,
  "description": "SEO crawler worker for scoring pages and storing results in PostgreSQL.",
  "main": "dist/crawler.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/crawler.js",
    "dev": "ts-node src/crawler.ts",
    "crawl": "npm run dev",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "dotenv": "^17.3.1",
    "p-limit": "^7.3.0",
    "pg": "^8.20.0",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
